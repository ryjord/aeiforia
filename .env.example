# Supabase — public client config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — server-only secret. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# NASA Earthdata Login token — server-only, powers the ocean microplastics layer.
# Get one at https://urs.earthdata.nasa.gov/users/new (Profile > Generate Token).
NASA_EARTHDATA_TOKEN=
